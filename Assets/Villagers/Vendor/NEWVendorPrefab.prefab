  interactableIcon: {fileID: 3103688106124949148}
  stallUI: {fileID: 0}
  audioSource: {fileID: 0}
  name: Stefan
  portrait: {fileID: 21300000, guid: 6c5acea75cbee41c7983f640353e6031, type: 3}
  morningDialogue: Time for a fresh start to another new day!
  dayDialogue: I've got plenty of wood here, if that's what you're looking for.
  eveningDialogue: Eyes on the wood? It's freshly chopped and mighty succulent, but
    we're closed for now.
  nightDialogue: Gotta get ready for another busy day tomorrow.
  template: {fileID: 11400000, guid: 92108cf9cddc9d64094a1d20d4216e40, type: 2}
  overrides:
  - definition: {fileID: 11400000, guid: 12e3962eca40d1a4c8eec9d46806f104, type: 2}
    responseOverride: Yeah, I can spare the time! Shop's closed anyhow.
  - definition: {fileID: 11400000, guid: d1b153fabde7d1147b589e96d64eb37a, type: 2}
    responseOverride: Take a gander at my luscious specimens.
  - definition: {fileID: 11400000, guid: c598a0568cfa89f44aa1788ffadc37d4, type: 2}
    responseOverride: Don't be a stranger, now.

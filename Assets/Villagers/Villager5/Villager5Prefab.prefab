  m_GameObject: {fileID: 4959334826077419890}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1204cb198c937da4c9c8ae5554a70914, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcBehavior
  _hungerCost: 2
  interactableIcon: {fileID: 0}
  isMerchant: 0
  merchantStall: {fileID: 0}
  audioSource: {fileID: 0}
  name: Pie
  portrait: {fileID: 21300000, guid: 6495d487ba8ef450caf11ef7620bff12, type: 3}
  morningDialogue: Name's Pie. Can you guess what I like to eat in the morning?
  dayDialogue: I'd ask you to get me a pie, but I don't think that's an item in the
    game.
  eveningDialogue: What if you made a pie that could do anything?
  nightDialogue: I can't go to sleep. I'm thinking too much about pie.
  template: {fileID: 0}
  overrides:
  - definition: {fileID: 11400000, guid: c598a0568cfa89f44aa1788ffadc37d4, type: 2}
    responseOverride: If you find pie paradise, please let me know.
  - definition: {fileID: 11400000, guid: 12e3962eca40d1a4c8eec9d46806f104, type: 2}
    responseOverride: I'd love to go out. I wish they made liquid pie, though. Doesn't
      even need to be alcoholic.
  smallBeerDialogue: It may be small, but it's enough to wash down a good pie. Now
    all I need is the pie.
  mediumBeerDialogue: Lookit that-- a good sized beer! If you poured it into a pie
    pan, how high would it fill to?
  largeBeerDialogue: Looks like we're getting rowdy tonight! This might loosen my
    tongue too much... you don't wanna hear about *that* pie story.
  returnFromTavernDialogue: Almost as good as a fresh pie! Let's talk again sometime.
  normalDialogueSound: {fileID: 0}
  shopDialogueSound: {fileID: 0}
  CanInteract: 1
